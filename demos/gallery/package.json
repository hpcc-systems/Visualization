{
    "private": true,
    "name": "@hpcc-js/demo-gallery",
    "scripts": {
        "clean": "rimraf --glob types dist *.tsbuildinfo",
        "compile-umd": "tsc --module umd --outDir ./src-umd",
        "compile-umd-watch": "npm run compile-umd -- -w",
        "gen-filejson": "node ./util/dir2json ./samples",
        "build": "run-s compile-umd gen-filejson",
        "test": "mocha-headless-chrome -t 300000 -a allow-file-access-from-files -f ./test.html",
        "update": "npx --yes npm-check-updates -u -t minor"
    },
    "dependencies": {
        "es6-promise": "4.2.8",
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@hpcc-js/api": "^2.14.5",
        "@hpcc-js/dataflow": "^9.5.0",
        "@hpcc-js/chart": "^2.86.5",
        "@hpcc-js/codemirror": "^2.66.4",
        "@hpcc-js/codemirror-shim": "^2.38.1",
        "@hpcc-js/common": "^2.73.5",
        "@hpcc-js/comms": "^2.102.4",
        "@hpcc-js/composite": "^2.9.8",
        "@hpcc-js/ddl-shim": "^2.25.2",
        "@hpcc-js/deck-shim": "^2.9.1",
        "@hpcc-js/dgrid": "^2.34.6",
        "@hpcc-js/dgrid-shim": "^2.27.1",
        "@hpcc-js/dgrid2": "^2.5.5",
        "@hpcc-js/form": "^2.12.6",
        "@hpcc-js/graph": "^2.87.4",
        "@hpcc-js/html": "^2.44.5",
        "@hpcc-js/layout": "^2.51.6",
        "@hpcc-js/leaflet-shim": "^2.6.1",
        "@hpcc-js/map": "^2.79.6",
        "@hpcc-js/map-deck": "^2.9.5",
        "@hpcc-js/marshaller": "^2.28.10",
        "@hpcc-js/other": "^2.17.6",
        "@hpcc-js/phosphor": "^2.20.7",
        "@hpcc-js/phosphor-shim": "^2.17.1",
        "@hpcc-js/preact-shim": "^2.19.2",
        "@hpcc-js/react": "^2.55.5",
        "@hpcc-js/timeline": "^2.57.4",
        "@hpcc-js/tree": "^2.45.3",
        "@hpcc-js/util": "^2.53.2",
        "d3-selection": "^1",
        "systemjs": "0.21.6"
    }
}